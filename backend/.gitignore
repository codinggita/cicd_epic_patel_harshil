# ============================================================
# BACKEND .gitignore
# ============================================================

# Dependencies
node_modules/

# Environment files (real secrets - never commit these)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Note: .env.example is intentionally NOT ignored.
# It serves as a template for other developers.

# Large data files (seed data, exports, datasets)
dataset.json
*.json.gz

# Planning and temporary files (not part of the codebase)
implementation_plan.md
*.notes.md

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build output
dist/
build/
out/

# Test coverage
coverage/
.nyc_output/

# OS files
.DS_Store
Thumbs.db
ehthumbs.db

# Editor configs
.vscode/
.idea/
*.suo
*.sw?

# Uploads and temp folders
uploads/
temp/
tmp/
